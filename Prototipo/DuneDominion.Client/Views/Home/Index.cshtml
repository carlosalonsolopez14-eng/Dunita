@model string

@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center py-16">
    <h1 class="text-5xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-emerald-400 to-cyan-400 mb-8">
        DUNE: ARRAKIS DOMINION DISTRIBUTED
    </h1>
    <p class="text-xl text-slate-400 mb-12 max-w-2xl mx-auto">
        Gestiona tu imperio en Arrakis con una arquitectura multi-agente avanzada.
        Cría criaturas exóticas, construye enclaves y domina el desierto.
    </p>

    <div class="glass-panel rounded-2xl p-8 max-w-md mx-auto">
        <h2 class="text-2xl font-semibold mb-6 text-white">Comenzar Juego</h2>

        <form method="post" asp-action="NuevaPartida" class="mb-4">
            <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-4 px-6 rounded-lg transition-colors text-lg">
                🎮 Nueva Partida (Escenario Arrakeen)
            </button>
        </form>

        <form method="post" asp-action="CargarPartida">
            <button type="submit" class="w-full bg-cyan-600 hover:bg-cyan-700 text-white font-bold py-4 px-6 rounded-lg transition-colors text-lg">
                📁 Cargar Partida
            </button>
        </form>

        @if (ViewBag.Error != null)
        {
            <div class="mt-4 p-4 bg-red-600/20 border border-red-500 rounded-lg text-red-300">
                @ViewBag.Error
            </div>
        }
    </div>

    <div class="mt-12 text-slate-400">
        <p>Explora la <a href="/index.html" class="text-cyan-400 hover:underline">documentación completa</a> del proyecto</p>
    </div>
</div>