<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dunita</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .dune-bg {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        }
        .glass-panel {
            background: rgba(30, 41, 59, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body class="dune-bg text-slate-200 min-h-screen">
    <header class="bg-slate-800/50 py-4">
        <div class="max-w-7xl mx-auto px-4">
            <h1 class="text-2xl font-bold text-emerald-400">🏜️ DUNITA - Dune Dominion</h1>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8">
        @RenderBody()
    </main>

    <footer class="bg-slate-800/50 py-4 mt-16">
        <div class="max-w-7xl mx-auto px-4 text-center text-slate-400">
            <p>&copy; 2026 Dunita Project - Arquitectura Multi-Agente</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>